{
  "manifest_version": 3,
  "name": "Пустоши: Выживание",
  "version": "2.0.0",
  "description": "Постапокалиптическая RPG с динамическим боем",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Пустоши",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}